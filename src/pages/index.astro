---
import Layout from "../layouts/Layout.astro";
import { ArrowUpRight, Calendar, Search } from "@lucide/astro";
import HeroCalendarPreview from "../components/HeroCalendarPreview.vue";
import { getAllContent } from "../../lib/all-content";
import type { ContentCard } from "../../lib/all-content";
import { getCategoryMeta } from "../../lib/pages";
import { graph, websiteNode } from "../../lib/structured-data";
import { homepageQuestions } from "../../lib/homepage-questions";

const cards = [...getAllContent()].sort((a, b) => a.title.localeCompare(b.title, "de"));

// H1 rotator (client-side, see script below): real example questions the
// site can answer, built from data/homepage-questions.yaml's per-category
// templates - see lib/homepage-questions.ts.
const rotatingQuestions = homepageQuestions();
const tags = [...new Set([...cards.flatMap((c) => c.tags)].map((t) => t.toLowerCase()))].sort((a, b) => a.localeCompare(b, "de"))

// Google-SERP-like clustering: one result group per type, most relevant
// items (ContentCard.featured) shown directly, the rest collapsed behind a
// "show more" toggle so e.g. Feiertage's 200+ countries don't drown out
// everything else.
const groupsByType = new Map<string, ContentCard[]>();
for (const card of cards) {
  const group = groupsByType.get(card.type);
  if (group) group.push(card);
  else groupsByType.set(card.type, [card]);
}
const groups = [...groupsByType.entries()].map(([type, items]) => ({
  type,
  description: getCategoryMeta(items[0].category).description,
  items: [...items].sort((a, b) => Number(b.featured) - Number(a.featured)),
  moreCount: items.filter((i) => !i.featured).length,
}));

const homeDescription =
  "Strukturierte Antworten auf Wann-Fragen als Kalender-Abo - Feiertage, Urlaubsfenster, Saisonkalender und mehr, frei kombinierbar und einzeln abonnierbar.";
const structuredData = graph([
  websiteNode({ name: "Wann-O-Meter", url: new URL("/", Astro.site).href, description: homeDescription }),
]);

// Preview under the hero (Bayern, since it's the one worked example the
// homepage copy below also names) - HeroCalendarPreview resolves the actual
// window data itself client-side (same /api/v1/calendar/{id}.json route the
// real calendar uses), and swaps to whichever layers the H1 rotator (script
// below) is currently naming.
const previewLayerIds = ["feiertage--de-by", "schulferien--by", "saisonkalender--spargel"];
---

<Layout
  title="Wann ist was?"
  description={homeDescription}
  structuredData={structuredData}
>
  <div class="hero">
    <div class="hero-text">
      <h1 id="h1-rotator">Wann ist was?</h1>
      <p class="lead">{homeDescription}</p>
      <p class="today-teaser">
        <a id="today-teaser-link" href="/kalender/">
          Was heute (nicht) Saison hat, Feiertag ist oder ansteht — im Kalender nachsehen.
        </a>
      </p>
      <p><a class="cta" href="/kalender/"><Calendar size={16} /> Ebenen-Kalender öffnen <ArrowUpRight size={16} /></a></p>
    </div>

    <HeroCalendarPreview initialLayerIds={previewLayerIds} client:visible />
  </div>

  <h2>Alle Themen durchsuchen</h2>
  <div class="search-wrap">
    <Search size={16} class="search-icon" aria-hidden="true" />
    <input
      type="search"
      id="search-input"
      placeholder="Titel oder Tag suchen…"
      aria-label="Seiten durchsuchen"
    />
  </div>

  {
    tags.length > 0 && (
      <p class="tags">
        {tags.map((tag) => (
          <button type="button" class="badge tag-filter" data-tag={tag}>{tag}</button>
        ))}
      </p>
    )
  }

  <div id="results">
    {
      groups.map((group) => (
        <section class="group" data-type={group.type}>
          <h2>
            {group.type} <span class="count">{group.items.length}</span>
          </h2>
          {group.description && <p class="group-description">{group.description}</p>}
          <ul class="cards narrow">
            {group.items.map((c) => (
              <li
                data-title={c.title.toLowerCase()}
                data-tags={c.tags.join(",").toLowerCase()}
                data-featured={String(c.featured)}
                hidden={!c.featured}
              >
                <a href={c.url}>{c.title}</a>
              </li>
            ))}
          </ul>
          {group.moreCount > 0 && (
            <button type="button" class="more" data-group={group.type}>
              +{group.moreCount} weitere anzeigen
            </button>
          )}
        </section>
      ))
    }
  </div>
  <p id="no-results" hidden>Keine Treffer.</p>
</Layout>

<style>
  /* Rough 2-line fallback for the no-JS/pre-hydration paint - the rotator
     script below measures and overrides this with the exact height the
     tallest question needs once it runs, since some questions wrap to 3
     lines at this column's width and a fixed guess would still shift. */
  #h1-rotator {
    min-height: 2.5em;
  }
  .hero {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }
  .hero-text {
    flex: 1;
    min-width: 0;
  }
  @media (max-width: 45rem) {
    .hero {
      flex-direction: column;
    }
  }
  .lead {
    font-size: 1.05rem;
    max-width: 34rem;
  }
  .today-teaser {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .today-teaser a {
    color: var(--muted);
  }
  .today-teaser a:hover {
    color: var(--accent);
  }
  .cta {
    margin: 0.5rem 0 1rem;
  }
  .search-wrap {
    position: relative;
    width: 100%;
    max-width: 24rem;
    margin: 1rem 0;
  }
  .search-icon {
    position: absolute;
    left: 0.65rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    pointer-events: none;
  }
  #search-input {
    width: 100%;
    padding-left: 2.1rem;
    display: block;
  }
  .tags {
    margin-bottom: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag-filter {
    cursor: pointer;
    font: inherit;
  }
  .tag-filter.active {
    background: var(--accent);
    color: var(--accent-ink);
  }
  .group h2 {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .group-description {
    margin: -0.5rem 0 0.75rem;
    color: var(--muted);
    font-size: 0.85rem;
  }
  .count {
    color: var(--muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    font-weight: 400;
  }
  .narrow {
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
  }
  .narrow a {
    padding: 0.5rem 0.7rem;
    font-size: 0.88rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .more {
    margin: 0.7rem 0 2rem;
  }
</style>

<!-- Not in the scoped <style> above: Astro's scoping works by stamping a
     data-astro-cid-* attribute onto elements in the server-rendered markup,
     but the rotator script (further down) builds this <em> at runtime via
     document.createElement - it never gets that attribute, so a scoped
     selector silently never matches it. is:global sidesteps that; #h1-rotator
     is unique to this page so there's no leak risk in scoping it by hand. -->
<style is:global>
  /* The topic clause of each rotating question (see lib/homepage-questions.ts's
     before/emphasis/after split) - a light italic serif contrast against the
     page's sans everywhere else. System serif stack, no webfont to load for
     one decorative accent. */
  #h1-rotator em {
    font-style: italic;
    font-weight: 300;
    font-family: Georgia, "Times New Roman", serif;
  }
</style>

<script>
  // Plain-vanilla substring filter, no framework/search-index dependency -
  // dataset is a few hundred items at most, well below the threshold where
  // that would pay off. Non-featured items start hidden (collapsed into
  // their type's cluster); a group's "show more" button reveals them
  // permanently, and an active search/tag filter always overrides the
  // collapse so nothing is unreachable.
  const search = document.getElementById("search-input") as HTMLInputElement;
  const noResults = document.getElementById("no-results")!;
  const groups = Array.from(document.querySelectorAll<HTMLElement>(".group"));
  const tagButtons = document.querySelectorAll<HTMLButtonElement>(".tag-filter");
  const moreButtons = document.querySelectorAll<HTMLButtonElement>(".more");

  let activeTag: string | null = null;
  const expandedGroups = new Set<string>();

  function apply() {
    const query = search.value.trim().toLowerCase();
    const searchActive = query !== "" || activeTag !== null;
    let totalVisible = 0;

    for (const group of groups) {
      const groupName = group.dataset.type ?? "";
      let visibleInGroup = 0;
      for (const entry of group.querySelectorAll<HTMLLIElement>("li")) {
        const title = entry.dataset.title ?? "";
        const tags = entry.dataset.tags ?? "";
        const isFeatured = entry.dataset.featured === "true";
        const matchesQuery = query === "" || title.includes(query) || tags.includes(query);
        const matchesTag = activeTag === null || tags.split(",").includes(activeTag);
        const collapsed = !searchActive && !isFeatured && !expandedGroups.has(groupName);
        const show = matchesQuery && matchesTag && !collapsed;
        entry.hidden = !show;
        if (show) visibleInGroup++;
      }
      group.hidden = visibleInGroup === 0;
      totalVisible += visibleInGroup;

      const moreButton = group.querySelector<HTMLButtonElement>(".more");
      if (moreButton) moreButton.hidden = searchActive || expandedGroups.has(groupName);
    }

    noResults.hidden = totalVisible > 0;
  }

  search.addEventListener("input", apply);
  for (const button of tagButtons) {
    button.addEventListener("click", () => {
      // Lowercased to match `tags` above (itself lowercased from data-tags) -
      // without this, clicking a tag whose displayed casing isn't already
      // all-lowercase (e.g. "Feiertage") silently matches nothing.
      const tagValue = (button.dataset.tag ?? "").toLowerCase();
      activeTag = activeTag === tagValue ? null : tagValue;
      for (const b of tagButtons) {
        b.classList.toggle("active", (b.dataset.tag ?? "").toLowerCase() === activeTag && activeTag !== null);
      }
      apply();
    });
  }
  for (const button of moreButtons) {
    button.addEventListener("click", () => {
      expandedGroups.add(button.dataset.group ?? "");
      apply();
    });
  }

  // Nav's "Durchsuchen" link points at "/#search-input" - focus it on
  // arrival. Covers both a fresh page load and clicking the link while
  // already on "/" (same-document hash change, no reload/DOMContentLoaded).
  function focusSearchIfTargeted() {
    if (location.hash !== "#search-input") return;
    // preventScroll + an explicit centered scrollIntoView, instead of the
    // browser's default jump-to-top-of-viewport anchor behavior - otherwise
    // the input lands right at the top edge, easy to miss.
    search.focus({ preventScroll: true });
    search.scrollIntoView({ block: "center", behavior: "smooth" });
  }
  focusSearchIfTargeted();
  window.addEventListener("hashchange", focusSearchIfTargeted);
</script>

<script>
  import { pickTodayTeaser } from "../../lib/today-teaser";

  const teaserLink = document.getElementById("today-teaser-link");
  if (teaserLink instanceof HTMLAnchorElement) {
    const d = new Date();
    const today = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
    fetch("/api/v1/today-feed.json")
      .then((r) => r.json())
      .then((entries) => {
        const teaser = pickTodayTeaser(entries, today);
        // No hit (or the fetch/parse below failed) -> keep the static
        // default text/href already in the template, never show nothing.
        if (!teaser) return;
        teaserLink.textContent = teaser.text;
        teaserLink.href = `/kalender/?day=${teaser.day}&layers=${teaser.entryId}`;
      })
      .catch(() => {});
  }
</script>

<script define:vars={{ questions: rotatingQuestions }}>
  // Cycles the H1 through real questions the site can answer - the static
  // generic H1 (set in the template) is the no-JS/SEO fallback. Skipped
  // entirely for prefers-reduced-motion (WCAG 2.2.2: no unpausable
  // auto-updating text).
  const h1 = document.getElementById("h1-rotator");
  if (h1 && questions.length > 0 && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    // Renders {before, emphasis, after} (lib/homepage-questions.ts) as text +
    // <em> + text instead of one flat string - the topic clause (e.g.
    // "Schulferien und Feiertage in Mecklenburg-Vorpommern") reads distinctly
    // from the generic "Wann ist/sind..." opener. Used by both the real H1
    // update below and the height probe, so the probe measures the exact
    // markup that'll render (italic glyphs aren't the same width as regular
    // ones - a flat-text measurement could under/over-reserve height).
    function renderQuestion(el, question) {
      const em = document.createElement("em");
      em.textContent = question.emphasis;
      el.replaceChildren(document.createTextNode(question.before), em, document.createTextNode(question.after));
    }

    // Reserves exactly the height the tallest question needs to wrap to at
    // the H1's *actual* current width - the CSS min-height below is only a
    // rough fallback (2 lines), which the longer combined Schulferien+
    // Feiertage questions can exceed, especially now that the H1 shares the
    // row with the calendar preview and has less width than it used to.
    // Measured with a detached clone instead of a fixed lookup table so it
    // stays correct across font-loading, zoom, and viewport width, none of
    // which a precomputed table could account for.
    function reserveH1Height() {
      const probe = document.createElement("h1");
      probe.className = h1.className;
      Object.assign(probe.style, {
        position: "absolute",
        visibility: "hidden",
        pointerEvents: "none",
        minHeight: "0",
        margin: "0",
        width: `${h1.getBoundingClientRect().width}px`,
      });
      document.body.appendChild(probe);
      let max = 0;
      for (const question of questions) {
        renderQuestion(probe, question);
        max = Math.max(max, probe.offsetHeight);
      }
      document.body.removeChild(probe);
      h1.style.minHeight = `${max}px`;
    }
    reserveH1Height();
    let resizeTimer;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(reserveH1Height, 200);
    });

    let q = questions
    setInterval(() => {
      const i = Math.floor(Math.random() * q.length);
      const question = questions[i];
      renderQuestion(h1, question);
      // Tells HeroCalendarPreview.vue which layers this sentence is about -
      // a CustomEvent instead of a shared Vue parent, so this script can
      // keep owning the static-H1/reduced-motion fallback untouched.
      window.dispatchEvent(new CustomEvent("homepage-rotate", { detail: { layerIds: question.layerIds } }));
      // Web Animations API, not a CSS class toggle - a class-based
      // @keyframes animation doesn't replay on repeated triggers without a
      // reflow hack; .animate() just restarts. Slides up into place from
      // below with a slight overshoot ("small bounce") via the easing curve.
      h1.animate(
        [
          { transform: "translateY(0.6em)", opacity: 0 },
          { transform: "translateY(-0.06em)", opacity: 1, offset: 0.7 },
          { transform: "translateY(0)", opacity: 1 },
        ],
        { duration: 450, easing: "cubic-bezier(0.34, 1.56, 0.64, 1)" },
      );
      q = questions.filter((_, j) => j !== i);
      if (q.length === 0) q = questions;
    }, 3000);
  }
</script>
