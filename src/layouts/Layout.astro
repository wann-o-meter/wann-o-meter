---
import "../styles/global.css";
import { ArrowUpRight, Calendar, Monitor, Moon, Search, Sun } from "@lucide/astro";
import { feedbackIssueUrl, feedbackMailtoUrl, newSourceIssueUrl } from "../../lib/github-issue";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  // Pre-built JSON-LD document from lib/structured-data.ts's graph() - kept
  // as a plain prop instead of a named slot so every page can pass it
  // without needing to know about <script> placement.
  structuredData?: object;
}
const { title, description, wide = false, structuredData } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
// The arrow reads as "go here" - pointless (and a little odd) to show it
// while already on /kalender/ or one of its sub-pages (e.g. /kalender/embed/).
const onKalenderPage = Astro.url.pathname.startsWith("/kalender");
const pageTitle = `${title} · Wann-O-Meter`;
const ogDescription = description ?? "Strukturierte Antworten auf Wann-Fragen, als Kalender-Abo.";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Applies a saved light/dark override before first paint, so there's
      // no flash of the wrong theme - runs synchronously as the very first
      // thing in <head>. No override stored (or "system") means the
      // prefers-color-scheme media query in global.css decides, same as
      // before this toggle existed.
      const t = localStorage.getItem("theme");
      if (t === "light" || t === "dark") document.documentElement.dataset.theme = t;
    </script>
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:site_name" content="Wann-O-Meter" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL("/og-image.png", Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={new URL("/og-image.png", Astro.site).href} />

    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body>
    <header>
      <div class:list={["wrap", "header-bar", { wide }]}>
        <a href="/" class="brand">Wann-<span class="brand-accent">O</span>-Meter</a>
        <a id="today-indicator" class="today-indicator" href="/kalender/"></a>
        <nav>
          <a href="/kalender/"><Calendar size={16} /> Kalender {!onKalenderPage && <ArrowUpRight size={14} />}</a>
          <span class="nav-divider" aria-hidden="true"></span>
          <a href="/#search-input"><Search size={16} /> Durchsuchen</a>
        </nav>
        <button type="button" id="theme-toggle" class="theme-toggle" title="Farbschema wechseln (System/Hell/Dunkel)">
          <Monitor size={16} data-theme-icon="system" class="active" />
          <Sun size={16} data-theme-icon="light" />
          <Moon size={16} data-theme-icon="dark" />
        </button>
      </div>
    </header>
    <main class:list={["wrap", { wide }]}>
      <slot />
    </main>
    <footer>
      <div class:list={["wrap", "footer-bar", { wide }]}>
        <p>
          Alle Seiten, Einzel-Kalender-Feeds (ICS) und JSON-Daten sind kostenlos und bleiben es -
          für private Nutzung. Kommerzielle Volumen-Nutzung nur nach Vereinbarung.
        </p>
        <p>Angaben ohne Gewähr. Quelle &amp; Stand stehen bei jedem Zeitfenster dabei.</p>
        <p>
          <a href="/impressum">Impressum</a> &middot; <a href="/datenschutz">Datenschutz</a> &middot;{" "}
          <a href={newSourceIssueUrl()}>Quelle vorschlagen</a> &middot;{" "}
          <a href={feedbackMailtoUrl()}>Feedback per Mail</a> &middot;{" "}
          <a href={feedbackIssueUrl()}>Feedback auf GitHub</a>
        </p>
      </div>
    </footer>

    <script>
      // Client-side, not Astro frontmatter: this is a static build, so a
      // date computed at build time would freeze at whenever the site was
      // last built, not update as real days/weeks pass for a visitor.
      import { formatTodayLabel } from "../../lib/date-display";
      const el = document.getElementById("today-indicator");
      if (el instanceof HTMLAnchorElement) {
        el.textContent = formatTodayLabel();
        // Kalender.vue reads ?day= to jump straight to that day's week view.
        const d = new Date();
        const iso = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
        el.href = `/kalender/?day=${iso}`;
      }

      // Light/dark/system toggle. "system" is the implicit default (no
      // localStorage entry, no data-theme attribute) - global.css's
      // prefers-color-scheme media query decides. Explicit "light"/"dark"
      // pin the theme via [data-theme] regardless of the OS setting; the
      // <script is:inline> above in <head> already applied any saved
      // override before first paint, this just keeps the button in sync
      // and lets it cycle through the three states.
      const THEME_LABELS = { system: "System", light: "Hell", dark: "Dunkel" };
      const themeToggle = document.getElementById("theme-toggle");
      function currentTheme() {
        const t = localStorage.getItem("theme");
        return t === "light" || t === "dark" ? t : "system";
      }
      function renderThemeToggle() {
        if (!themeToggle) return;
        const t = currentTheme();
        // Icon-only now (see the 3 <Monitor|Sun|Moon> in the template above) -
        // toggle which one is visible instead of swapping text, and carry the
        // same state in aria-label since there's no visible text left for it.
        // A CSS class instead of the `hidden` attribute/IDL property - that
        // property's reflection onto SVG elements is inconsistent enough
        // across browsers that it silently left all three icons visible.
        themeToggle.setAttribute("aria-label", `Farbschema: ${THEME_LABELS[t]}`);
        for (const icon of themeToggle.querySelectorAll("[data-theme-icon]")) {
          icon.classList.toggle("active", icon.getAttribute("data-theme-icon") === t);
        }
      }
      renderThemeToggle();
      themeToggle?.addEventListener("click", () => {
        const order = ["system", "light", "dark"];
        const next = order[(order.indexOf(currentTheme()) + 1) % order.length];
        if (next === "system") {
          localStorage.removeItem("theme");
          delete document.documentElement.dataset.theme;
        } else {
          localStorage.setItem("theme", next);
          document.documentElement.dataset.theme = next;
        }
        renderThemeToggle();
      });

      // Cmd+K (Mac) / Ctrl+K (everyone else) jumps to the homepage search,
      // same target as the "Durchsuchen" nav link - focuses it directly if
      // we're already on "/", otherwise navigates there.
      document.addEventListener("keydown", (e) => {
        if (e.key.toLowerCase() !== "k" || !(e.metaKey || e.ctrlKey)) return;
        e.preventDefault();
        const input = document.getElementById("search-input");
        if (input instanceof HTMLInputElement) {
          input.focus({ preventScroll: true });
          input.scrollIntoView({ block: "center", behavior: "smooth" });
        } else {
          window.location.href = "/#search-input";
        }
      });
    </script>
  </body>
</html>

<style>
  .wrap {
    max-width: 62rem;
    margin: 0 auto;
    padding-left: 1.75rem;
    padding-right: 1.75rem;
  }
  .wrap.wide {
    max-width: 88rem;
  }
  @media (max-width: 30rem) {
    .wrap {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }

  header {
    border-bottom: 1px solid var(--line);
  }
  .header-bar {
    padding-top: 1.1rem;
    padding-bottom: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem 1.5rem;
  }
  .brand {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
    color: var(--ink);
    text-decoration: none;
  }
  .brand .brand-accent {
    color: var(--accent);
  }
  .today-indicator {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-decoration: none;
  }
  .today-indicator:hover {
    color: var(--accent);
  }
  nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.3rem 1.3rem;
    font-size: 0.9rem;
  }
  .nav-divider {
    width: 1px;
    height: 1em;
    background: var(--line);
  }
  nav a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--ink);
    text-decoration: none;
    padding: 0.3rem 0;
  }
  nav a:hover {
    color: var(--accent);
  }
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem;
  }
  .theme-toggle [data-theme-icon] {
    display: none;
  }
  .theme-toggle [data-theme-icon].active {
    display: block;
  }

  main {
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  footer {
    margin-top: 3rem;
    border-top: 1px solid var(--line);
  }
  .footer-bar {
    padding-top: 1.25rem;
    padding-bottom: 2rem;
    color: var(--muted);
    font-size: 0.85rem;
  }
  .footer-bar p {
    margin: 0 0 0.4rem;
  }
</style>
